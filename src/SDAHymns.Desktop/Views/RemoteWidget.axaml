<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SDAHymns.Desktop.ViewModels"
        xmlns:models="using:SDAHymns.Desktop.Models"
        mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="520"
        x:Class="SDAHymns.Desktop.Views.RemoteWidget"
        x:DataType="vm:RemoteWidgetViewModel"
        Title="{DynamicResource Remote.Title}"
        Width="320"
        Height="760"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="None"
        Background="Transparent"
        Topmost="{Binding IsAlwaysOnTop}">

    <Window.Styles>
        <Style Selector="Border.remote-container">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3E3E52"/>
        </Style>

        <Style Selector="Border.custom-titlebar">
            <Setter Property="Background" Value="#16161E"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="12 12 0 0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.titlebar-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.titlebar-button:pointerover">
            <Setter Property="Background" Value="#2A2A3C"/>
        </Style>

        <Style Selector="Button.titlebar-button.close:pointerover">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Border.status-panel">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style Selector="TextBlock.status-title">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="TextBlock.status-subtitle">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style Selector="TextBox.hymn-input">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#3E3E52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style Selector="TextBox.hymn-input:focus">
            <Setter Property="BorderBrush" Value="#6366F1"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#7C3AED"/>
        </Style>

        <Style Selector="Button.primary:pressed">
            <Setter Property="Background" Value="#5B21B6"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#3E3E52"/>
        </Style>

        <Style Selector="Button.numpad">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.numpad:pointerover">
            <Setter Property="Background" Value="#3E3E52"/>
        </Style>

        <Style Selector="Button.icon-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="Button.icon-button:pointerover">
            <Setter Property="Background" Value="#2A2A3C"/>
        </Style>

        <Style Selector="Button.icon-button.active">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Border.bottom-toolbar">
            <Setter Property="Background" Value="#16161E"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="0 0 12 12"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>
    </Window.Styles>

    <Border Classes="remote-container">
        <DockPanel>
            <!-- Custom Title Bar -->
            <Border Classes="custom-titlebar" DockPanel.Dock="Top" Name="TitleBar" PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Classes="title" Text="{DynamicResource Remote.Title}"/>
 
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                        <Button Classes="titlebar-button" Content="≡" ToolTip.Tip="{DynamicResource Remote.Menu}">
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                    <MenuItem Header="{DynamicResource Remote.AdvancedMode}" Click="AdvancedMode_Click"/>
                                    <MenuItem Header="{DynamicResource Remote.ToggleNumPad}" Command="{Binding $parent[Window].((vm:RemoteWidgetViewModel)DataContext).ToggleNumberPadCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="{DynamicResource Remote.About}"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Classes="titlebar-button" Content="_" Click="Minimize_Click" ToolTip.Tip="{DynamicResource Remote.Minimize}"/>
                        <Button Classes="titlebar-button close" Content="×" Click="Close_Click" ToolTip.Tip="{DynamicResource Text.Close}"/>
                    </StackPanel>
                </Grid>
            </Border>
 
            <!-- Update Notification Banner -->
            <Border IsVisible="{Binding IsUpdateAvailable}" 
                    Background="#2E7D32" 
                    Padding="12,8" 
                    DockPanel.Dock="Top">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{DynamicResource Update.Available}" 
                                   Foreground="White" 
                                   FontSize="12" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding LatestVersion, StringFormat='v{0}'}" 
                                   Foreground="#C8E6C9" 
                                   FontSize="10"/>
                    </StackPanel>
                    
                    <ProgressBar Grid.Column="1" 
                                 IsVisible="{Binding IsDownloadingUpdate}" 
                                 Value="{Binding DownloadProgress}" 
                                 Width="60" 
                                 Height="16" 
                                 Margin="8,0"
                                 VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Button Content="✓" 
                                Command="{Binding UpdateNowCommand}" 
                                IsVisible="{Binding !IsDownloadingUpdate}"
                                Padding="8,4" 
                                MinWidth="28"
                                FontSize="10"
                                Background="#1B5E20"
                                ToolTip.Tip="{DynamicResource Update.Now}"/>
                        <Button Content="✕" 
                                Command="{Binding DismissUpdateCommand}" 
                                IsVisible="{Binding !IsDownloadingUpdate}"
                                Padding="8,4" 
                                MinWidth="28"
                                FontSize="10"
                                Background="Transparent"
                                ToolTip.Tip="{DynamicResource Update.Later}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Bottom Toolbar -->
            <Border Classes="bottom-toolbar" DockPanel.Dock="Bottom">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <Button Classes="icon-button" Content="📌" Command="{Binding ToggleAlwaysOnTopCommand}"
                            Classes.active="{Binding IsAlwaysOnTop}"
                            ToolTip.Tip="{DynamicResource Remote.AlwaysOnTop}"/>
                    <Button Classes="icon-button" Content="🔒" Command="{Binding ToggleLockPositionCommand}"
                            Classes.active="{Binding IsPositionLocked}"
                            ToolTip.Tip="{DynamicResource Remote.LockPosition}"/>
                    <Button Classes="icon-button" Content="⌨" Command="{Binding ToggleNumberPadCommand}"
                            Classes.active="{Binding ShowNumberPad}"
                            ToolTip.Tip="{DynamicResource Remote.ToggleNumPad}"/>
                    <Button Classes="icon-button" Content="📺" Command="{Binding TogglePresenterViewCommand}"
                            ToolTip.Tip="{DynamicResource Remote.PresenterView}"/>
                    <Button Classes="icon-button" Content="⚙" Click="AdvancedMode_Click"
                            ToolTip.Tip="{DynamicResource Remote.AdvancedMode}"/>
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="12">
                    <!-- Current Hymn Display -->
                    <Border Classes="status-panel">
                        <StackPanel>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <TextBlock Grid.Column="0" 
                                           Text="{Binding ActiveHymnNumber}" 
                                           Foreground="#FFD700" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding ActiveHymnTitle}" 
                                           Foreground="White" 
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           TextWrapping="Wrap" 
                                           VerticalAlignment="Center"
                                           TextAlignment="Left"/>
                            </Grid>
                            <TextBlock Text="{Binding VerseIndicator}" 
                                       Foreground="#9CA3AF" 
                                       FontSize="14" 
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Category Selection -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Remote.Category}" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategoryItem}"
                                  Background="#2A2A3C"
                                  Foreground="White"
                                  BorderBrush="#3E3E52"
                                  Margin="0,0,0,8">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:LocalizedCategory">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Hymn Input -->
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Remote.LoadHymn}" Foreground="#9CA3AF" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox Classes="hymn-input"
                                 Text="{Binding HymnNumberInput}"
                                 Watermark="{DynamicResource Remote.EnterNumber}"
                                 Name="HymnInput">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding LoadHymnCommand}"/>
                            </TextBox.KeyBindings>
                        </TextBox>
                    </StackPanel>

                    <!-- Number Pad -->
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*" IsVisible="{Binding ShowNumberPad}" ColumnSpacing="6" RowSpacing="6">
                        <!-- Row 1: 7,8,9 -->
                        <Button Grid.Row="0" Grid.Column="0" Classes="numpad" Content="7" Command="{Binding NumberPadPressCommand}" CommandParameter="7"/>
                        <Button Grid.Row="0" Grid.Column="1" Classes="numpad" Content="8" Command="{Binding NumberPadPressCommand}" CommandParameter="8"/>
                        <Button Grid.Row="0" Grid.Column="2" Classes="numpad" Content="9" Command="{Binding NumberPadPressCommand}" CommandParameter="9"/>

                        <!-- Row 2: 4,5,6 -->
                        <Button Grid.Row="1" Grid.Column="0" Classes="numpad" Content="4" Command="{Binding NumberPadPressCommand}" CommandParameter="4"/>
                        <Button Grid.Row="1" Grid.Column="1" Classes="numpad" Content="5" Command="{Binding NumberPadPressCommand}" CommandParameter="5"/>
                        <Button Grid.Row="1" Grid.Column="2" Classes="numpad" Content="6" Command="{Binding NumberPadPressCommand}" CommandParameter="6"/>

                        <!-- Row 3: 1,2,3 -->
                        <Button Grid.Row="2" Grid.Column="0" Classes="numpad" Content="1" Command="{Binding NumberPadPressCommand}" CommandParameter="1"/>
                        <Button Grid.Row="2" Grid.Column="1" Classes="numpad" Content="2" Command="{Binding NumberPadPressCommand}" CommandParameter="2"/>
                        <Button Grid.Row="2" Grid.Column="2" Classes="numpad" Content="3" Command="{Binding NumberPadPressCommand}" CommandParameter="3"/>

                        <!-- Row 4: ←,0,⏎ -->
                        <Button Grid.Row="3" Grid.Column="0" Classes="numpad" Content="←" Command="{Binding NumberPadBackspaceCommand}"/>
                        <Button Grid.Row="3" Grid.Column="1" Classes="numpad" Content="0" Command="{Binding NumberPadPressCommand}" CommandParameter="0"/>
                        <Button Grid.Row="3" Grid.Column="2" Classes="numpad" Content="⏎" Command="{Binding LoadHymnCommand}"/>
                    </Grid>

                    <!-- Action Buttons -->
                    <StackPanel Spacing="8">
                        <Button Classes="primary" Content="{DynamicResource Remote.Show}" Command="{Binding LoadHymnCommand}" HorizontalAlignment="Stretch"/>
                        <Button Classes="secondary" Content="{DynamicResource Remote.BlackScreenBtn}" Command="{Binding BlankDisplayCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Quick Slots -->
                    <StackPanel Spacing="5" Margin="0,5">
                        <TextBlock Text="{DynamicResource Remote.QuickSlotsTitle}" FontSize="10" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                        
                        <!-- Row 1: Slots 1-4 -->
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBox Text="{Binding Slot1Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot1Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="1" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="1" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBox Text="{Binding Slot2Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot2Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="2" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="2" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBox Text="{Binding Slot3Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot3Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="3" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="3" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="2">
                                <TextBox Text="{Binding Slot4Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot4Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="4" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="4" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Slots 5-8 -->
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4" Margin="0,4,0,0">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBox Text="{Binding Slot5Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot5Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="5" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="5" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBox Text="{Binding Slot6Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot6Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="6" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="6" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBox Text="{Binding Slot7Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot7Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="7" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="7" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Spacing="2">
                                <TextBox Text="{Binding Slot8Label, Mode=TwoWay}" Watermark="..." FontSize="10" FontWeight="Bold" Height="28" Padding="4" Background="#111118" Opacity="0.8" HorizontalAlignment="Stretch" TextAlignment="Center"/>
                                <TextBox Text="{Binding Slot8Text, Mode=TwoWay}" Watermark="---" FontSize="14" Height="36" Padding="4" Background="#16161E" BorderThickness="1" BorderBrush="#3E3E52"/>
                                <Button Content="{DynamicResource Remote.Show}" Command="{Binding LoadFromSlotCommand}" CommandParameter="8" 
                                        Background="#2A2A3C" Foreground="White" FontSize="11" HorizontalAlignment="Stretch" Padding="0,4"/>
                                <Button Content="{DynamicResource Remote.Set}" Command="{Binding SaveCurrentToSlotCommand}" CommandParameter="8" 
                                        FontSize="9" HorizontalAlignment="Stretch" Padding="0,2" Background="#16161E" Opacity="0.7"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Verse Navigation -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0" Classes="secondary" Content="{DynamicResource Remote.Previous}" Command="{Binding PreviousVerseCommand}"/>
                        <Button Grid.Column="1" Classes="secondary" Content="{DynamicResource Remote.Next}" Command="{Binding NextVerseCommand}"/>
                    </Grid>

                    <!-- Audio Control -->
                    <Button Classes="primary"
                            Content="{DynamicResource Remote.PlayAudio}"
                            Command="{Binding ToggleAudioCommand}"
                            IsVisible="{Binding IsAudioAvailable}"
                            HorizontalAlignment="Stretch"/>

                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#9CA3AF"
                               FontSize="11"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
